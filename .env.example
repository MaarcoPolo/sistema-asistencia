# ── Ejemplo de variables de entorno ──────────────────────────────────────────
# INSTRUCCIONES:
#   1. Copiar este archivo: cp .env.example .env
#   2. Llenar los valores reales en .env
#   3. NUNCA commitear el archivo .env al repositorio
#
# El archivo .env es leído automáticamente por docker-compose.

# ── Base de datos ─────────────────────────────────────────────────────────────
DB_NAME=asistencia_db
DB_USERNAME=postgres
DB_PASSWORD=CAMBIA_ESTA_CONTRASENA

# ── JWT ───────────────────────────────────────────────────────────────────────
# Genera un secreto seguro con: openssl rand -base64 64
JWT_SECRET=GENERA_UN_SECRETO_SEGURO_DE_AL_MENOS_64_CARACTERES_AQUI
